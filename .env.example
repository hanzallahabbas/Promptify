# =============================================================
#  PROMPTIFY — Environment Variables
#  File: .env  (rename this file to .env and fill in values)
# =============================================================

# MongoDB connection string
# Option A — MongoDB Atlas (cloud):
#   MONGO_URI=mongodb+srv://yourusername:yourpassword@cluster0.xxxxx.mongodb.net/
# Option B — Local MongoDB:
#   MONGO_URI=mongodb://localhost:27017/
MONGO_URI=mongodb://localhost:27017/

# Database name (will be created automatically)
DB_NAME=promptify

# Secret key for signing JWT tokens
# IMPORTANT: Change this to a long random string in production!
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-this-to-a-long-random-secret-key
